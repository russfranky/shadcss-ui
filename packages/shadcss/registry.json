{
  "note": "This is a custom shadcss manifest describing an HTML+CSS component library \u2014 it is NOT a shadcn CLI registry and intentionally does not conform to https://ui.shadcn.com/schema.json. It is a machine-readable reference only (no CLI consumes it). Each component lists its CSS file, dependencies, example markup, and the classes it defines.",
  "name": "shadcss",
  "version": "0.1.1",
  "description": "shadcn's beauty, no JS framework. A modular HTML+CSS-only component library built on modern web standards.",
  "homepage": "https://github.com/russfranky/shadcss-ui",
  "license": "MIT",
  "style": "dist/shadcss.min.css",
  "tokens": {
    "css": "src/base/tokens.css",
    "description": "All design tokens live as HSL CSS custom properties on :root. Override any token to retheme the entire framework."
  },
  "components": [
    {
      "name": "accordion",
      "file": "src/components/accordion.css",
      "deps": [
        "base/tokens",
        "base/theme"
      ],
      "description": "Collapsible content panels built on native <details>.",
      "markup": "<div class=\"accordion\"><details name=\"X\"><summary>Q</summary><div class=\"accordion-content\">A</div></details></div>",
      "classes": [
        "accordion",
        "accordion-content"
      ],
      "attributes": [
        "name (on details for exclusive mode)"
      ]
    },
    {
      "name": "alert",
      "file": "src/components/alert.css",
      "deps": [
        "base/tokens",
        "base/theme"
      ],
      "description": "Inline message banner with icon, title, description.",
      "markup": "<div class=\"alert alert-info\" role=\"alert\"><svg aria-hidden=\"true\">\u2026</svg><div><div class=\"alert-title\">T</div><div class=\"alert-description\">D</div></div></div>",
      "classes": [
        "alert",
        "alert-title",
        "alert-description",
        "alert-dismissible",
        "alert-default",
        "alert-info",
        "alert-success",
        "alert-warning",
        "alert-destructive"
      ]
    },
    {
      "name": "alert-dialog",
      "file": "src/components/alert-dialog.css",
      "deps": [
        "base/tokens",
        "base/theme",
        "dialog"
      ],
      "description": "Confirmation modal for destructive actions.",
      "markup": "<dialog class=\"alert-dialog\" id=\"X\" role=\"alertdialog\" aria-labelledby=\"X-title\" aria-describedby=\"X-desc\"><div class=\"alert-dialog-header\"><div class=\"alert-dialog-title\" id=\"X-title\">T</div><div class=\"alert-dialog-description\" id=\"X-desc\">D</div></div><div class=\"alert-dialog-footer\"><form method=\"dialog\"><button class=\"btn btn-ghost\">Cancel</button></form><button class=\"btn btn-destructive\">Confirm</button></div></dialog>",
      "classes": [
        "alert-dialog",
        "alert-dialog-header",
        "alert-dialog-title",
        "alert-dialog-description",
        "alert-dialog-body",
        "alert-dialog-footer"
      ]
    },
    {
      "name": "aspect-ratio",
      "file": "src/components/aspect-ratio.css",
      "deps": [
        "base/tokens"
      ],
      "description": "Lock an element to a width/height ratio.",
      "markup": "<div class=\"aspect-ratio\"><img src=\"\u2026\" alt=\"\u2026\"></div>",
      "classes": [
        "aspect-ratio",
        "aspect-square",
        "aspect-video",
        "aspect-photo",
        "aspect-portrait",
        "aspect-cinema",
        "aspect-wide",
        "aspect-ultra"
      ]
    },
    {
      "name": "avatar",
