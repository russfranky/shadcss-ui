      "deps": [
        "base/tokens"
      ],
      "description": "Pure-CSS month calendar. Day cells with today/selected/disabled states.",
      "markup": "<div class=\"calendar\"><div class=\"calendar-header\"><span class=\"calendar-title\">Month Year</span><div class=\"calendar-nav\"><button class=\"calendar-nav-btn\">\u2039</button><button class=\"calendar-nav-btn\">\u203a</button></div></div><div class=\"calendar-grid\"><span class=\"calendar-weekday\">S</span>\u2026<button class=\"calendar-day\">1</button>\u2026</div></div>",
      "classes": [
        "calendar",
        "calendar-header",
        "calendar-title",
        "calendar-nav",
        "calendar-nav-btn",
        "calendar-grid",
        "calendar-weekday",
        "calendar-day",
        "calendar-sm",
        "is-today",
        "outside"
      ]
    },
    {
      "name": "card",
      "file": "src/components/card.css",
      "deps": [
        "base/tokens"
      ],
      "description": "Container with header, content, footer zones.",
      "markup": "<div class=\"card\"><div class=\"card-header\"><div class=\"card-title\">T</div><div class=\"card-description\">D</div></div><div class=\"card-content\">\u2026</div><div class=\"card-footer\" data-justify=\"end\">\u2026</div></div>",
      "classes": [
        "card",
        "card-header",
        "card-title",
        "card-description",
        "card-content",
        "card-footer",
        "card-interactive"
      ],
      "notes": ".card-interactive provides hover/focus-visible styling but is not focusable on its own \u2014 add tabindex=\"0\" (and a role/href such as a wrapping <a>) so keyboard users can reach it and the focus-visible ring can fire."
    },
