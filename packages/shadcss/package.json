{
  "name": "@russfranky/shadcss",
  "version": "0.1.7",
  "description": "shadcn's beauty, no JS framework. A modular HTML+CSS-only component library built on modern web standards.",
  "type": "module",
  "main": "dist/shadcss.min.css",
  "style": "dist/shadcss.min.css",
  "files": [
    "dist",
    "src",
    "registry.json",
    "AI_GUIDE.md"
  ],
  "exports": {
    ".": "./dist/shadcss.min.css",
    "./unminified": "./dist/shadcss.css",
    "./src": "./src/shadcss.css"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "prepublishOnly": "node scripts/build.mjs"
  },
  "keywords": [
    "css",
    "html",
    "shadcn",
    "components",
    "design-system",
    "no-javascript",
    "framework",
    "modular",
    "lightweight",
    "tailwind"
  ],
  "author": "russfranky",
  "license": "MIT",
  "homepage": "https://github.com/russfranky/shadcss-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/russfranky/shadcss-ui.git",
    "directory": "packages/shadcss"
  },
  "bugs": "https://github.com/russfranky/shadcss-ui/issues",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "lightningcss": "^1.29.0"
  }
}
